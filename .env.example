# Brain API — environment reference
# Copy to .env and fill in values. .env is git-ignored.
# Production secrets live in Azure Key Vault via managed identity.

# ---- Identity & environment ----
NODE_ENV=development
SERVICE_NAME=brain-server
SERVICE_VERSION=0.1.0
PORT=3000

# ---- Postgres ----
DATABASE_URL=postgres://brain:brain@localhost:5432/brain
DATABASE_POOL_MAX=10
DATABASE_STATEMENT_TIMEOUT_MS=30000

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Auth ----
AUTH_JWKS_URL=https://auth.brain.fi/.well-known/jwks.json
AUTH_ISSUER=https://auth.brain.fi
AUTH_AUDIENCE=brain-api
AUTH_CLOCK_TOLERANCE_SECONDS=5
IDEMPOTENCY_TTL_SECONDS=86400
REQUEST_BODY_LIMIT_BYTES=52428800

# ---- CORS ----
# Comma-separated list of allowed origins. Never use "*" in staging/prod.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Observability ----
LOG_LEVEL=info
LOG_PRETTY=true

# ---- Sandbox / demo mode ----
# Set to true to run end-to-end demos without live Policy/Agent services.
# See docs/sandbox-mode.md for the full runbook.
BRAIN_DEMO_MODE=false

# ---- LLM (OpenAI) ----
# Required for /wiki/question to return real answers.
OPENAI_API_KEY=
WIKI_LLM_MODEL=gpt-4o-mini
WIKI_EMBED_MODEL=text-embedding-3-small

# ---- LLM (Anthropic — legacy / tests only) ----
ANTHROPIC_API_KEY=

# ---- Plaid ----
# Required for tools/plaid-sandbox CLI (pnpm run plaid:sandbox).
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_INSTITUTION_ID=ins_109508

# ---- MCP / on-chain (Base Sepolia) ----
RPC_URL=https://sepolia.base.org
MCP_AGENT_REGISTRY_ADDRESS=0xd1558828ef31630164aa8942dd41bc63a4d8bed7
POLICY_REGISTRY_ADDRESS=0x683893ccd84d9a3487095d09fed324b6b8ea2501
BRAIN_MCP_DEV_AUTH_BYPASS=false

# ---- Brain-shipped (internal) agents ----
# URL of the Python reconciliation agent (services/agents). When set, the agent
# router delegates the reconciliation agent to it; unset, reconciliation uses
# the default in-process AgentService.
# RECONCILIATION_AGENT_URL=http://localhost:8000
# Intent-classifier strategy for the agent router. "rules" (default) uses
# deterministic token overlap; "embedding" matches paraphrases via embeddings
# with the rules classifier kept as a fallback (uses OPENAI_API_KEY when set).
AGENT_INTENT_CLASSIFIER=rules

# ---- On-chain rails ----
# BRAIN_SESSION_KEY=0x...64hex...
# BASE_RPC_URL=https://sepolia.base.org

# ---- Audit anchor ----
# AUDIT_PUBLISHER_KEY=0x...64hex...
AUDIT_ANCHOR_ADDRESS=0xb900add824064098342c869ff83efdeb05eb95ce
AUDIT_ANCHOR_INTERVAL_MS=3600000

# ---- Blob storage ----
# Leave unset to use in-memory blob adapter (default for local dev).
# Set both for Azure Blob Storage in staging/production.
# AZURE_STORAGE_ACCOUNT=
# AZURE_STORAGE_CONTAINER=brain-artifacts
