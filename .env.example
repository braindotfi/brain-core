# Brain API — environment reference
# Copy to .env and fill in values. .env is git-ignored.
# Production secrets live in Azure Key Vault via managed identity.

# ---- Identity & environment ----
NODE_ENV=development
SERVICE_NAME=brain-server
SERVICE_VERSION=0.1.0
PORT=3000

# ---- Postgres ----
DATABASE_URL=postgres://brain:brain@localhost:5432/brain
DATABASE_POOL_MAX=10
DATABASE_STATEMENT_TIMEOUT_MS=30000
# H-14: the Wiki layer connects with this URL as the read-only brain_wiki_reader
# role (SELECT anywhere; INSERT/UPDATE/DELETE only on wiki_* tables). Provision the
# role via services/wiki/migrations/0005_wiki_role.sql + a separate password /
# Azure managed identity. Leave unset in dev/test to share DATABASE_URL.
# BRAIN_WIKI_DB_URL=postgres://brain_wiki_reader:CHANGEME@localhost:5432/brain

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Auth ----
AUTH_JWKS_URL=https://auth.brain.fi/.well-known/jwks.json
AUTH_ISSUER=https://auth.brain.fi
AUTH_AUDIENCE=brain-api
AUTH_CLOCK_TOLERANCE_SECONDS=5
IDEMPOTENCY_TTL_SECONDS=86400
REQUEST_BODY_LIMIT_BYTES=52428800

# ---- CORS ----
# Comma-separated list of allowed origins. Never use "*" in staging/prod.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Observability ----
LOG_LEVEL=info
LOG_PRETTY=true

# ---- Sandbox / demo mode ----
# Set to true to run end-to-end demos without live Policy/Agent services.
# See docs/sandbox-mode.md for the full runbook.
BRAIN_DEMO_MODE=false

# Prod-capable demo provisioning for the BrainSaaS "Brain Playground".
# Set to true to expose POST /v1/demo/provision-run (fresh-tenant-per-run seed +
# scoped agent JWT) and the public GET /v1/reference/yield-venues catalog.
# Unlike BRAIN_DEMO_MODE (which throws in production), this is safe to enable on
# the testnet prod stack: provisioning seeds real tenant-scoped data via the app
# role (RLS on) and the minted token is short-lived. The token carries a broad
# scope set INCLUDING audit:admin (for the per-run anchor-publish path) — by
# design the SIWX `partner` role stays least-privilege and does NOT grant
# audit:admin; only this demo provisioning token does. Default false.
BRAIN_DEMO_PROVISION_ENABLED=false

# Per-user production tenants for a trusted BFF (e.g. Brain Finance / BrainMVB).
# Set to true to expose POST /v1/auth/service-token: mints a scoped JWT for a
# STABLE per-user tenant (idempotent empty tenant + active payment agent, no demo
# data). Production counterpart to provision-run. Callers send X-Service-Token-Auth
# equal to BRAIN_SERVICE_TOKEN_SECRET. Scope ceiling = reads + propose + approve
# ONLY (no payment_intent:execute / audit:admin / policy:write). On
# NODE_ENV=production the boot fence also requires
# BRAIN_SERVICE_TOKEN_TESTNET_ATTESTED=true. Default false.
BRAIN_SERVICE_TOKEN_ENABLED=false
# BRAIN_SERVICE_TOKEN_SECRET=        # required when enabled (Key Vault in prod)
# BRAIN_SERVICE_TOKEN_TESTNET_ATTESTED=false

# ---- Full-docker local dev (pnpm run dev / docker-compose.dev.yml) ----
# The dev compose overlay sets these automatically for the containerized API; you
# do NOT need them in this .env to run `pnpm run dev`. Documented here for clarity:
#   NODE_ENV=development, BRAIN_DEMO_MODE=true, BRAIN_MCP_DEV_AUTH_BYPASS=true,
#   BLOB_BACKEND=memory, DATABASE_URL=postgres://brain:brain@postgres:5432/brain,
#   REDIS_URL=redis://redis:6379  (service DNS names on the compose network).
# In demo mode the JWT verifier uses a STATIC HS256 secret (no JWKS fetch):
#   AUTH_JWT_SECRET=brain-demo-mode-insecure-dev-only   (dev-only; never in prod)
# Mint a token to call the API on http://localhost:3001 either via the in-demo
# endpoint `GET /v1/demo/token`, or with the dev-token tool using that secret:
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml run --rm \
#     -e AUTH_JWT_SECRET=brain-demo-mode-insecure-dev-only \
#     api pnpm -C tools/dev-token run start -- --tenant tnt_00000000010000000000000000

# ---- LLM (OpenAI) ----
# Required for /wiki/question to return real answers.
OPENAI_API_KEY=
WIKI_LLM_MODEL=gpt-4o-mini
WIKI_EMBED_MODEL=text-embedding-3-small

# ---- LLM (Anthropic — legacy / tests only) ----
ANTHROPIC_API_KEY=

# ---- Plaid ----
# Required for tools/plaid-sandbox CLI (pnpm run plaid:sandbox) AND the H-05
# Plaid Transfer ACH rail (services/execution/src/rails/ach-plaid.ts). The ACH
# rail reuses these vars (spec named them BRAIN_PLAID_*; the repo already had
# PLAID_* for the same Plaid account).
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_INSTITUTION_ID=ins_109508
# Set to 1 to run the (blocked-by-default) Plaid sandbox round-trip integration test.
# BRAIN_PLAID_SANDBOX_INTEGRATION=1

# ---- MCP / on-chain (Base Sepolia) ----
RPC_URL=https://sepolia.base.org
MCP_AGENT_REGISTRY_ADDRESS=0xcE7Ce9dd95c17E1F4E27D49249b6fdb015f3A7e0
POLICY_REGISTRY_ADDRESS=0x683893ccd84d9a3487095d09fed324b6b8ea2501
BRAIN_MCP_DEV_AUTH_BYPASS=false

# ---- Brain-shipped (internal) agents ----
# URL of the Python reconciliation agent (services/agents). When set, the agent
# router delegates the reconciliation agent to it; unset, reconciliation uses
# the default in-process AgentService.
# RECONCILIATION_AGENT_URL=http://localhost:8000
# Intent-classifier strategy for the agent router. "rules" (default) uses
# deterministic token overlap; "embedding" matches paraphrases via embeddings
# with the rules classifier kept as a fallback (uses OPENAI_API_KEY when set).
AGENT_INTENT_CLASSIFIER=rules

# ---- On-chain rails (H-06 Base rail via BrainSmartAccount.executeViaSessionKey) ----
# BRAIN_SESSION_KEY=0x...64hex...
# BASE_RPC_URL=https://sepolia.base.org
# Base chain id: 8453 mainnet / 84532 sepolia (default).
# BRAIN_BASE_CHAIN_ID=84532
# BrainSaaS "Brain Playground" demo settlement recipient (used only when
# BRAIN_DEMO_PROVISION_ENABLED=true). The provision-run seed sets this as the ETH
# `aliases` target on approved vendors so the marquee AP payment settles via the
# onchain_base rail. It MUST equal the address the BrainSmartAccount session key
# is granted to send to (GrantSessionKeyNative's allowedRecipient) — otherwise
# executeViaSessionKey reverts with TargetNotAllowed(address). Defaults to the
# testnet demo holder in code if unset.
# BRAIN_DEMO_ONCHAIN_RECIPIENT=0x41D4ce9D9Fe968Ca1230bDc296B28fdc9AA6FF6E
# Azure Key Vault URL holding the rail's signing key. The viem Account proxies
# signing to Key Vault via managed identity — the raw key never enters process
# memory. Unset → live on-chain rail disabled (dev/test use the fail-closed stub).
# BRAIN_AZURE_KEY_VAULT_URL=https://brain-onchain.vault.azure.net/

# ---- Audit anchor ----
# AUDIT_PUBLISHER_KEY=0x...64hex...
AUDIT_ANCHOR_ADDRESS=0xb900add824064098342c869ff83efdeb05eb95ce
AUDIT_ANCHOR_INTERVAL_MS=3600000

# ---- Blob storage ----
# Leave unset to use in-memory blob adapter (default for local dev).
# Set both for Azure Blob Storage in staging/production.
# AZURE_STORAGE_ACCOUNT=
# AZURE_STORAGE_CONTAINER=brain-artifacts
