{
  "name": "brain",
  "version": "0.1.0",
  "private": true,
  "description": "Brain Finance Inc. — financial intelligence protocol (MVP).",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --filter './services/**' --filter '!./services/agents' run build",
    "lint": "pnpm -r --filter './services/**' --filter '!./services/agents' run lint && pnpm run prettier:check",
    "lint:fix": "pnpm -r --filter './services/**' --filter '!./services/agents' run lint:fix && pnpm run prettier:write",
    "typecheck": "pnpm -r --filter './services/**' --filter '!./services/agents' run typecheck",
    "test": "pnpm -r --filter './services/**' --filter '!./services/agents' run test",
    "test:coverage": "pnpm -r --filter './services/**' --filter '!./services/agents' run test:coverage",
    "prettier:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,yml,yaml,md}\" --ignore-path .prettierignore",
    "prettier:write": "prettier --write \"**/*.{ts,tsx,js,jsx,json,yml,yaml,md}\" --ignore-path .prettierignore",
    "agents:lint": "cd services/agents && uv run ruff check . && uv run black --check .",
    "agents:typecheck": "cd services/agents && uv run mypy --strict brain_agents",
    "agents:test": "cd services/agents && uv run pytest",
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test",
    "dev:up": "./scripts/dev-up.sh",
    "dev:down": "docker compose down",
    "plaid:sandbox": "pnpm -C tools/plaid-sandbox run start"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2",
    "@vitest/coverage-v8": "^2.1.2"
  }
}
