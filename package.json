{
  "name": "brain",
  "version": "0.1.0",
  "private": true,
  "description": "Brain Finance Inc. — financial intelligence protocol (MVP).",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --filter './shared/**' --filter './services/**' --filter '!./services/agents' --filter './clients/**' run build",
    "check-scope-vocab": "node scripts/check-scope-vocab.mjs",
    "lint": "pnpm -r --filter './services/**' --filter '!./services/agents' --filter './clients/**' run lint && pnpm run prettier:check && pnpm run check-scope-vocab",
    "lint:fix": "pnpm -r --filter './services/**' --filter '!./services/agents' --filter './clients/**' run lint:fix && pnpm run prettier:write",
    "typecheck": "pnpm -r --filter './services/**' --filter '!./services/agents' --filter './clients/**' run typecheck",
    "test": "pnpm -r --filter './services/**' --filter '!./services/agents' --filter './clients/**' run test",
    "test:coverage": "pnpm -r --filter './services/**' --filter '!./services/agents' --filter './clients/**' run test:coverage",
    "prettier:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,yml,yaml,md}\" --ignore-path .prettierignore",
    "prettier:write": "prettier --write \"**/*.{ts,tsx,js,jsx,json,yml,yaml,md}\" --ignore-path .prettierignore",
    "agents:lint": "cd services/agents && uv run ruff check . && uv run black --check .",
    "agents:typecheck": "cd services/agents && uv run mypy --strict brain_agents",
    "agents:test": "cd services/agents && uv run pytest",
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test",
    "dev:up": "./scripts/dev-up.sh",
    "dev:down": "docker compose down",
    "plaid:sandbox": "pnpm -C tools/plaid-sandbox run start",
    "demo:reset": "pnpm -C tools/demo-reset run reset"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^17.6.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "vitest": "^3.2.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "^6.4.2",
      "ws@<8.20.1": "^8.20.1"
    }
  }
}
