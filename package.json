{
  "name": "brain",
  "version": "0.0.4",
  "private": true,
  "description": "Brain Finance Inc. — financial intelligence protocol (MVP).",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "build": "pnpm -r --filter './shared/**' --filter './services/**' --filter '!./services/agents' --filter './clients/**' run build",
    "check-scope-vocab": "node scripts/check-scope-vocab.mjs",
    "check-gate-bypass": "node scripts/check-gate-bypass.mjs",
    "check-payment-intent-loaders": "node scripts/check-payment-intent-loaders.mjs",
    "check-no-em-dashes": "node scripts/strip-em-dashes.mjs",
    "check-promotion-readiness": "node scripts/check-promotion-readiness.mjs",
    "check-wiki-no-ledger-write": "node scripts/check-wiki-no-ledger-write.mjs",
    "check-policy-no-wiki-read": "node scripts/check-policy-no-wiki-read.mjs",
    "check-no-onchain-pii": "node scripts/check-no-onchain-pii.mjs",
    "check-docs-drift": "node scripts/check-docs-drift.mjs",
    "check-rails-catalog-drift": "node scripts/check-rails-catalog-drift.mjs",
    "check-escrow-audit-marker": "node scripts/check-escrow-audit-marker.mjs",
    "check-audit-status": "node scripts/check-audit-status.mjs",
    "check-risk-register-drift": "node scripts/check-risk-register-drift.mjs",
    "check-contract-abi-drift": "node scripts/check-contract-abi-drift.mjs",
    "check-blob-purge-callsite": "node scripts/check-blob-purge-callsite.mjs",
    "check-connector-descriptors": "node scripts/check-connector-descriptors.mjs",
    "scaffold-connector": "node scripts/scaffold-connector.mjs",
    "production-readiness": "node scripts/production-readiness.mjs",
    "readiness-snapshot": "node scripts/readiness-snapshot.mjs",
    "readiness-trend": "node scripts/readiness-trend.mjs",
    "test:scripts": "node --test scripts/__tests__/*.test.mjs",
    "lint:openapi": "npx --yes @redocly/cli@latest lint Brain_API_Specification.yaml",
    "lint": "pnpm -r --filter './shared/**' --filter './services/**' --filter '!./services/agents' --filter './clients/**' run lint && pnpm run prettier:check && pnpm run check-scope-vocab && pnpm run check-gate-bypass && pnpm run check-payment-intent-loaders && pnpm run check-no-em-dashes && pnpm run check-wiki-no-ledger-write && pnpm run check-policy-no-wiki-read && pnpm run check-no-onchain-pii && pnpm run check-docs-drift && pnpm run check-rails-catalog-drift && pnpm run check-escrow-audit-marker && pnpm run check-audit-status && pnpm run check-risk-register-drift && pnpm run check-contract-abi-drift && pnpm run check-blob-purge-callsite && pnpm run check-connector-descriptors && pnpm run lint:openapi",
    "lint:fix": "pnpm -r --filter './shared/**' --filter './services/**' --filter '!./services/agents' --filter './clients/**' run lint:fix && pnpm run prettier:write",
    "typecheck": "pnpm -r --filter './shared/**' --filter './services/**' --filter '!./services/agents' --filter './clients/**' run typecheck",
    "test": "pnpm -r --filter './shared/**' --filter './services/**' --filter '!./services/agents' --filter './clients/**' run test && pnpm run test:scripts",
    "test:coverage": "pnpm -r --filter './shared/**' --filter './services/**' --filter '!./services/agents' --filter './clients/**' run test:coverage",
    "prettier:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,yml,yaml,md}\" --ignore-path .prettierignore",
    "prettier:write": "prettier --write \"**/*.{ts,tsx,js,jsx,json,yml,yaml,md}\" --ignore-path .prettierignore",
    "agents:lint": "cd services/agents && uv run ruff check . && uv run black --check .",
    "agents:typecheck": "cd services/agents && uv run mypy --strict brain_agents",
    "agents:test": "cd services/agents && uv run pytest",
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test",
    "verify-audited-build": "node scripts/verify-audited-build.mjs",
    "dev": "./scripts/dev.sh",
    "dev:up": "./scripts/dev-up.sh",
    "dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "plaid:sandbox": "pnpm -C tools/plaid-sandbox run start",
    "demo:reset": "pnpm -C tools/demo-reset run reset",
    "demo:golden-path": "./scripts/demo/golden-path.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.7.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^17.6.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "vitest": "^4.1.8"
  }
}
