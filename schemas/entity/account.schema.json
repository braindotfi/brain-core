{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brain.fi/schemas/entity/account/v1",
  "title": "AccountEntity",
  "description": "A financial account — bank, card, or on-chain address. Sourced from Plaid, NetSuite, manual entry, or chain adapters.",
  "type": "object",
  "required": ["display_name", "kind"],
  "additionalProperties": false,
  "properties": {
    "display_name": { "type": "string", "minLength": 1, "maxLength": 200 },
    "kind": {
      "type": "string",
      "enum": ["bank_checking", "bank_savings", "card", "loan", "line_of_credit", "onchain"]
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "description": "ISO 4217 code; crypto uses the chain's native symbol."
    },
    "institution": { "type": "string", "maxLength": 200 },
    "mask": { "type": "string", "pattern": "^[\\dxX*]{3,6}$" },
    "external_id": { "type": "string", "maxLength": 256 },
    "chain": { "type": "string", "enum": ["base", "ethereum", "other"] },
    "address": { "type": "string", "pattern": "^0x[a-fA-F0-9]{40}$" }
  }
}
