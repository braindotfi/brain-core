# Foundry / Solidity
contracts/out/
contracts/cache/
contracts/broadcast/*/
!contracts/broadcast/*/run-latest.json
contracts/.forge-snapshots/
# forge-std is tracked as a git submodule under contracts/lib/forge-std
# (see .gitmodules). A cold `git clone --recursive` (or
# `git submodule update --init`) materializes it so reviewers can run
# `forge test` without a manual `forge install` step.
contracts/foundry.lock

