# Brain production-mode env template (testnet dev-live, Base Sepolia).
#
#   cp .env.prod.example .env.prod   then fill in the REQUIRED values.
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build
#
# This single file is used two ways:
#   • compose interpolation (the ${VAR} refs in docker-compose.prod.yml — DB and
#     MinIO passwords woven into connection URLs) — needs `--env-file .env.prod`.
#   • the api/agents container env_file (the app secrets the process reads).
#
# Values marked REQUIRED have no safe default and the api will refuse to boot in
# NODE_ENV=production without them (boot fences). Values marked TESTNET DEFAULT
# already have a baked-in default in the compose file; override before exposing
# the host.

# ─────────────────────────────────────────────────────────────────────────────
# Infrastructure passwords (compose interpolation — woven into the DB URLs)
# ─────────────────────────────────────────────────────────────────────────────
# Postgres bootstrap superuser/owner (migrate connects as this role).
POSTGRES_PASSWORD=brain
# The three application roles created by infra/db-roles.sql.
BRAIN_APP_DB_PASSWORD=brain_app
BRAIN_PRIVILEGED_DB_PASSWORD=brain_privileged
BRAIN_WIKI_DB_PASSWORD=brain_wiki_reader
# MinIO root credentials (also used as the S3 access key id / secret).
MINIO_ROOT_USER=brainminio
MINIO_ROOT_PASSWORD=brainminio
# Blob bucket name and S3 region (MinIO ignores region but the SDK requires one).
BLOB_CONTAINER=brain-artifacts
S3_REGION=us-east-1

# ─────────────────────────────────────────────────────────────────────────────
# C1 — Auth / JWKS (REQUIRED — production has no demo-token path)
# ─────────────────────────────────────────────────────────────────────────────
AUTH_JWKS_URL=
AUTH_ISSUER=
AUTH_AUDIENCE=

# ─────────────────────────────────────────────────────────────────────────────
# C2 — Source-credential encryption (REQUIRED in production)
# base64-encoded 32-byte AES-256-GCM key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ─────────────────────────────────────────────────────────────────────────────
BRAIN_SOURCE_CREDENTIAL_KEY=
BRAIN_SOURCE_CREDENTIAL_KEY_ID=testnet-v1

# ─────────────────────────────────────────────────────────────────────────────
# C4 — On-chain settlement + audit anchoring (Base Sepolia)
# ─────────────────────────────────────────────────────────────────────────────
BASE_RPC_URL=
# 64-hex session key (no 0x prefix) used to sign onchain_base settlements.
BRAIN_SESSION_KEY=
BRAIN_ONCHAIN_SMART_ACCOUNT=
# Audit Merkle anchor publisher (on-chain anchoring).
AUDIT_PUBLISHER_KEY=
AUDIT_ANCHOR_ADDRESS=

# ─────────────────────────────────────────────────────────────────────────────
# C5 — Contract addresses (use docs/deployment-2026-05-11.txt — the live set)
# ─────────────────────────────────────────────────────────────────────────────
POLICY_REGISTRY_ADDRESS=
MCP_AGENT_REGISTRY_ADDRESS=

# ─────────────────────────────────────────────────────────────────────────────
# C6 — Python reasoning agents (only needed with `--profile agents`)
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Shared secret the api uses to sign inbound calls to the agents (HMAC).
BRAIN_AGENTS_INBOUND_SECRET=
# Token the agents present back to the Brain API.
BRAIN_API_TOKEN=
