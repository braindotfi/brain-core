# Brain production-mode env template (testnet dev-live, Base Sepolia).
#
#   cp .env.prod.example .env.prod   then fill in the REQUIRED values.
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build
#
# This single file is used two ways:
#   • compose interpolation (the ${VAR} refs in docker-compose.prod.yml — DB and
#     MinIO passwords woven into connection URLs) — needs `--env-file .env.prod`.
#   • the api/agents container env_file (the app secrets the process reads).
#
# Values marked REQUIRED have no safe default and the api will refuse to boot in
# NODE_ENV=production without them (boot fences). Values marked TESTNET DEFAULT
# already have a baked-in default in the compose file; override before exposing
# the host.

# ─────────────────────────────────────────────────────────────────────────────
# Service identity (what GET /health reports). Without these the api falls back
# to the code defaults "brain-unknown" / "0.0.0-dev", so /health is meaningless.
# docker-compose.prod.yml sets SERVICE_NAME. SERVICE_VERSION is baked into the
# image at build time (git describe; see Dockerfile + main.yml) and is the single
# source of truth for /health. Do NOT set SERVICE_VERSION here — an env_file value
# overrides the image ENV and would re-pin a stale version. @brain/sdk versions
# independently.
# ─────────────────────────────────────────────────────────────────────────────
SERVICE_NAME=brain-api

# ─────────────────────────────────────────────────────────────────────────────
# Infrastructure passwords (compose interpolation — woven into the DB URLs)
# ─────────────────────────────────────────────────────────────────────────────
# Postgres bootstrap superuser/owner (migrate connects as this role).
POSTGRES_PASSWORD=brain
# The three application roles created by infra/db-roles.sql.
BRAIN_APP_DB_PASSWORD=brain_app
BRAIN_PRIVILEGED_DB_PASSWORD=brain_privileged
BRAIN_WIKI_DB_PASSWORD=brain_wiki_reader
# MinIO root credentials (also used as the S3 access key id / secret).
MINIO_ROOT_USER=brainminio
MINIO_ROOT_PASSWORD=brainminio
# Blob bucket name and S3 region (MinIO ignores region but the SDK requires one).
BLOB_CONTAINER=brain-artifacts
S3_REGION=us-east-1

# ─────────────────────────────────────────────────────────────────────────────
# C1 — Auth / JWKS (REQUIRED — production has no demo-token path)
#
# The compose stack runs a static-JWKS sidecar (service `jwks`) that publishes
# the PUBLIC half of AUTH_SIGN_KEY; the API verifies against it. So you only
# set the private signing key here — AUTH_JWKS_URL is wired in compose to the
# in-network sidecar (http://jwks:8085/.well-known/jwks.json), don't set it.
#
# Generate AUTH_SIGN_KEY (a private RS256 JWK, one line) with:
#   pnpm --filter @brain/static-jwks run generate
# Keep it secret. The same key signs SIWX tokens and mints test JWTs:
#   AUTH_SIGN_KEY='{...}' pnpm --filter @brain/dev-token start -- --tenant tnt_… --principal user_…
# ─────────────────────────────────────────────────────────────────────────────
AUTH_SIGN_KEY=
# iss/aud — must match what dev-token sets (these are the defaults it uses).
AUTH_ISSUER=https://auth.brain.fi
AUTH_AUDIENCE=brain-api

# ─────────────────────────────────────────────────────────────────────────────
# C2 — Source-credential encryption (AES-256-GCM key for Plaid tokens etc. at rest)
#
# VERIFIED BEHAVIOUR in NODE_ENV=production (shared/src/crypto/aes-gcm.ts):
#   • Azure Key Vault is the ONLY production-valid key source — set both
#     BRAIN_AZURE_KEY_VAULT_URL and BRAIN_SOURCE_CREDENTIAL_KEY_VAULT_NAME.
#   • BRAIN_SOURCE_CREDENTIAL_KEY (the env-var key) is FORBIDDEN in production —
#     setting it makes the API THROW AT BOOT. Leave it UNSET here. (It is only
#     for NODE_ENV != production.)
#   • With neither set, the API boots fine with NO credential encryption; the
#     only thing that fails (lazily) is STORING a real source credential. The
#     testnet demo path stores none, so leaving all of these blank is correct.
#
# Testnet default: leave ALL of the below blank (no real source ingestion).
# To enable Plaid/real source linking later, provision an Azure Key Vault and
# set the two KMS vars — or add a non-Azure escape hatch in aes-gcm.ts.
# ─────────────────────────────────────────────────────────────────────────────
# BRAIN_AZURE_KEY_VAULT_URL=https://<vault>.vault.azure.net
# BRAIN_SOURCE_CREDENTIAL_KEY_VAULT_NAME=<secret-name>
# BRAIN_SOURCE_CREDENTIAL_KEY=        # DO NOT set in production — boot fence throws

# ─────────────────────────────────────────────────────────────────────────────
# C4 — On-chain settlement + audit anchoring (Base Sepolia)
# ─────────────────────────────────────────────────────────────────────────────
BASE_RPC_URL=
# 64-hex session key (no 0x prefix) used to sign onchain_base settlements.
BRAIN_SESSION_KEY=
BRAIN_ONCHAIN_SMART_ACCOUNT=
# Audit Merkle anchor publisher (on-chain anchoring).
AUDIT_PUBLISHER_KEY=
AUDIT_ANCHOR_ADDRESS=

# ─────────────────────────────────────────────────────────────────────────────
# C5 — Contract addresses (use docs/deployment-2026-05-11.txt — the live set)
# ─────────────────────────────────────────────────────────────────────────────
POLICY_REGISTRY_ADDRESS=
MCP_AGENT_REGISTRY_ADDRESS=

# ─────────────────────────────────────────────────────────────────────────────
# C6 — Python reasoning agents (only needed with `--profile agents`)
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_OCR_MODEL=gpt-4o
# API to agents URL. Leave empty unless the agents profile is running.
DOCUMENT_EXTRACT_AGENT_URL=
# Shared secret the api uses to sign inbound calls to the agents (HMAC).
BRAIN_AGENTS_INBOUND_SECRET=
# Token the agents present back to the Brain API.
BRAIN_API_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# C7 — BrainSaaS Playground provisioning route (/v1/demo/provision-run)
#
# Powers the public playground: mints a READ+PROPOSE JWT and seeds a demo tenant.
# Boot fence (services/api/src/composition/demo-provision-fence.ts):
#   • If ENABLED=true, BRAIN_DEMO_PROVISION_SECRET is REQUIRED (the route is NOT
#     skipAuth — callers must send header `X-Demo-Provision-Auth: <secret>`).
#   • In NODE_ENV=production, ENABLED=true ALSO requires
#     BRAIN_DEMO_PROVISION_TESTNET_ATTESTED=true, or the api refuses to boot.
# Leave ENABLED=false to keep the route unregistered (fence inert).
# ─────────────────────────────────────────────────────────────────────────────
BRAIN_DEMO_PROVISION_ENABLED=false
BRAIN_DEMO_PROVISION_SECRET=
BRAIN_DEMO_PROVISION_TESTNET_ATTESTED=false

# ─────────────────────────────────────────────────────────────────────────────
# BFF service-token mint — POST /v1/auth/service-token (per-user prod tenants).
#   • Production counterpart to provision-run for a TRUSTED backend-for-frontend.
#   • If ENABLED=true, BRAIN_SERVICE_TOKEN_SECRET is REQUIRED (callers send
#     X-Service-Token-Auth equal to it); on NODE_ENV=production you also MUST set
#     BRAIN_SERVICE_TOKEN_TESTNET_ATTESTED=true, or the api refuses to boot.
#   • Minted scope ceiling = reads + propose ONLY (no approve / execute / audit
#     admin / policy write). Leave ENABLED=false to keep the route unregistered.
# ─────────────────────────────────────────────────────────────────────────────
BRAIN_SERVICE_TOKEN_ENABLED=false
BRAIN_SERVICE_TOKEN_SECRET=
BRAIN_SERVICE_TOKEN_TESTNET_ATTESTED=false

# ─────────────────────────────────────────────────────────────────────────────
# C8 — Surface gateway: email approval onboarding (surface-gateway service only)
#
# The surface-gateway container reads these from .env.prod via compose
# interpolation (docker-compose.prod.yml). Each surface is OFF by default, so the
# whole cluster is inert on the testnet stack.
#
# Boot fence (services/surface-gateway/src/main.ts): when EMAIL_ENABLED=true the
# process calls required() on EMAIL_ENDPOINT and EMAIL_API_KEY and THROWS AT BOOT
# if either is blank ("Missing required env var …"). EMAIL_FROM is optional (the
# per-tenant sender falls back to it). Set the ESP creds whenever you flip
# EMAIL_ENABLED on; otherwise leave all four as-is.
#
# (Slack/Teams follow the same _ENABLED-gated pattern with their own SLACK_*/
# TEAMS_* secrets in the compose file — likewise blank/false for testnet.)
# ─────────────────────────────────────────────────────────────────────────────
EMAIL_ENABLED=false
EMAIL_ENDPOINT=
EMAIL_API_KEY=
EMAIL_FROM=

# ─────────────────────────────────────────────────────────────────────────────
# Tuning (TESTNET DEFAULT — all have safe code defaults; override only if needed)
# ─────────────────────────────────────────────────────────────────────────────
# On-chain audit-anchor publisher cadence (ms). Code default 5000; the live box
# runs 3600000 (1h) to conserve testnet nonces/ETH.
AUDIT_ANCHOR_INTERVAL_MS=3600000
# Trailing lookback for agent cumulative-spend enforcement. Default 86400 (24h).
BRAIN_AGENT_WINDOW_LOOKBACK_SECONDS=86400
# 0x 32-byte policy-version digest the session key was granted for. Default zero.
BRAIN_ONCHAIN_POLICY_VERSION=
# BrainReputationRegistry address; presence wires reputation into PolicyService.
BRAIN_REPUTATION_REGISTRY_ADDRESS=
# Wiki Q&A models (OpenAI). Defaults: gpt-4o-mini / text-embedding-3-small.
WIKI_LLM_MODEL=gpt-4o-mini
WIKI_EMBED_MODEL=text-embedding-3-small

# ─────────────────────────────────────────────────────────────────────────────
# Demo seed (only used by the `--profile seed` one-shot — NOT for real prod)
# Populates a demo tenant + active policy + registered payment agent.
#   docker compose --env-file .env.prod -f docker-compose.prod.yml --profile seed run --rm seed
# ─────────────────────────────────────────────────────────────────────────────
# ETH address the seeded "AWS" counterparty resolves to (onchain_transfer target).
BRAIN_DEMO_ONCHAIN_RECIPIENT=
# Set to false to seed data only (skip the demo policy + agent).
BRAIN_SEED_DEMO_GOVERNANCE=true
