{
  "name": "@brain/core",
  "version": "0.1.0",
  "private": true,
  "description": "Brain core. Implements the surface ports and hosts the composition root. Private, UNLICENSED.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src test --max-warnings 0",
    "lint:fix": "eslint src test --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "dependencies": {
    "@brain/surfaces": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0"
  }
}
