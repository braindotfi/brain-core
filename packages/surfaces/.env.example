# Copy to .env and fill in. Never commit .env.

# Slack push app
SLACK_ENABLED=false
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_INSTALL_ADMIN_SECRET=
# Local development fallback only. Production resolves per-workspace bot tokens
# from the surface gateway Slack installation store.
SLACK_BOT_TOKEN=

# Microsoft Teams bot
TEAMS_ENABLED=false
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# Email approval
EMAIL_ENABLED=false
EMAIL_APPROVAL_BASE_URL=https://app.brain.fi/approve
EMAIL_TOKEN_SECRET=
