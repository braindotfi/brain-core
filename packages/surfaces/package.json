{
  "name": "@brain/surfaces",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-surface delivery and approval for Brain agents across Slack, Microsoft Teams, and email",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src test --max-warnings 0",
    "lint:fix": "eslint src test --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "dependencies": {
    "@slack/web-api": "^7.12.0",
    "botbuilder": "^4.23.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0"
  }
}
