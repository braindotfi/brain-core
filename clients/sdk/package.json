{
  "name": "@brain/sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Typed client for the Brain HTTP API. Generated from Brain_API_Specification.yaml.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "codegen": "openapi-typescript ../../Brain_API_Specification.yaml -o src/generated/openapi.d.ts",
    "codegen:check": "openapi-typescript ../../Brain_API_Specification.yaml -o /tmp/brain-sdk-openapi.d.ts && diff -q src/generated/openapi.d.ts /tmp/brain-sdk-openapi.d.ts",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "openapi-typescript": "^7.5.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2",
    "@vitest/coverage-v8": "^2.1.2"
  }
}
