{
  "version": 1,
  "rules": [
    {
      "id": "debt_optimization_within_cap",
      "applies_to": ["outbound_payment", "onchain_tx"],
      "when": {
        "agent.role": "debt_optimization",
        "amount.lte": { "currency": "USD", "value": "5000" }
      },
      "require": "single_signer",
      "execute": "confirm"
    },
    {
      "id": "debt_optimization_over_cap",
      "applies_to": ["outbound_payment", "onchain_tx"],
      "when": {
        "agent.role": "debt_optimization",
        "amount.gt": { "currency": "USD", "value": "5000" }
      },
      "execute": "reject"
    },
    {
      "id": "debt_optimization_advisory_auto",
      "applies_to": ["any"],
      "when": { "agent.role": "debt_optimization" },
      "execute": "auto"
    }
  ]
}
