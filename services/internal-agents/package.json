{
  "name": "@brain/internal-agents",
  "version": "0.0.4",
  "private": true,
  "description": "Brain-shipped (internal) agent catalog: definitions, handlers, policy templates, and on-chain registration payloads. Consumed by @brain/agent-router; never executes.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.6.2",
    "vitest": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.12.0",
    "@brain/policy": "workspace:*"
  },
  "dependencies": {
    "@brain/shared": "workspace:*",
    "@brain/schemas": "workspace:*"
  }
}
