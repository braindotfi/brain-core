{
  "name": "@brain/audit",
  "version": "0.1.0",
  "private": true,
  "description": "Append-only Merkle-chained log. On-chain anchor publisher via BrainAuditAnchor.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2",
    "@vitest/coverage-v8": "^2.1.2",
    "eslint": "^9.12.0",
    "fast-check": "^3.23.1"
  },
  "dependencies": {
    "@brain/api": "workspace:*",
    "fastify": "^5.0.0",
    "pg": "^8.13.0",
    "viem": "^2.21.32"
  }
}
