{
  "name": "@brain/ledger",
  "version": "0.1.0",
  "private": true,
  "description": "Normalized financial truth (Layer 2). Owns accounts, balances, transactions, counterparties, obligations, invoices, documents, categories, transfers, payment intents, reconciliation matches.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js"
    },
    "./repository": {
      "types": "./dist/repository/index.d.ts",
      "import": "./dist/repository/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2",
    "@vitest/coverage-v8": "^2.1.2",
    "eslint": "^9.12.0",
    "fast-check": "^3.23.1"
  },
  "dependencies": {
    "@brain/api": "workspace:*",
    "fastify": "^5.0.0",
    "pg": "^8.13.0"
  }
}
