{
  "name": "@brain/canonical",
  "version": "0.0.5",
  "private": true,
  "description": "Rich, versioned canonical domain stores. Ledger and Wiki are rebuildable projections of this layer (ingestion architecture §12).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.2",
    "vitest": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.12.0",
    "fast-check": "^3.23.1"
  },
  "dependencies": {
    "@brain/shared": "workspace:*",
    "pg": "^8.13.0"
  }
}
