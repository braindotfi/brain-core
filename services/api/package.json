{
  "name": "@brain/api",
  "version": "0.1.0",
  "private": true,
  "description": "Public HTTP API gateway. Terminates auth, routes to internal services. Hosts shared primitives consumed by every other service (src/shared/).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "brain-server": "./dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@aws-sdk/client-s3": "^3.670.0",
    "@aws-sdk/s3-request-presigner": "^3.670.0",
    "@azure/storage-blob": "^12.25.0",
    "@brain/agent-router": "workspace:*",
    "@brain/audit": "workspace:*",
    "@brain/execution": "workspace:*",
    "@brain/ledger": "workspace:*",
    "@brain/mcp": "workspace:*",
    "@brain/policy": "workspace:*",
    "@brain/raw": "workspace:*",
    "@brain/shared": "workspace:*",
    "@brain/wiki": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "~0.57.0",
    "@opentelemetry/resources": "^1.27.0",
    "@opentelemetry/sdk-trace-base": "~1.30.0",
    "@opentelemetry/sdk-trace-node": "~1.30.0",
    "@opentelemetry/semantic-conventions": "^1.27.0",
    "bullmq": "^5.21.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "hot-shots": "^10.2.1",
    "ioredis": "^5.4.1",
    "jose": "^5.9.3",
    "openai": "^4.68.0",
    "pg": "^8.13.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "siwe": "^2.3.2",
    "ulid": "^2.3.0",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.12.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "vitest": "^3.2.0"
  }
}
