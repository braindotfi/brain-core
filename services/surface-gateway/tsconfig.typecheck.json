{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "incremental": false,
    "noEmit": true,
    "paths": {
      "@brain/shared": ["../../shared/src/index.ts"],
      "@brain/shared/*": ["../../shared/src/*.ts"],
