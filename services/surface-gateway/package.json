{
  "name": "@brain/surface-gateway",
  "version": "0.0.5",
  "private": true,
  "description": "Inbound Slack, Teams, and email approval gateway for Brain surfaces.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint src test --max-warnings 0",
    "lint:fix": "eslint src test --fix",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@brain/core": "workspace:*",
    "@brain/execution": "workspace:*",
    "@brain/policy": "workspace:*",
    "@brain/shared": "workspace:*",
    "@brain/surfaces": "workspace:*",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "botbuilder": "^4.23.3",
    "fastify": "^5.0.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.12.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2",
    "vitest": "^4.1.8"
  }
}
