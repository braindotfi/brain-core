{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "0.0.1",
  "id": "${TEAMS_APP_ID}",
  "packageName": "fi.brain.teams",
  "developer": {
    "name": "Brain",
    "websiteUrl": "https://brain.fi",
    "privacyUrl": "https://brain.fi/privacy",
    "termsOfUseUrl": "https://brain.fi/terms"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "name": {
    "short": "Brain",
    "full": "Brain Approval Gateway"
  },
  "description": {
    "short": "Approve Brain agent proposals from Microsoft Teams.",
    "full": "Brain posts agent proposals to Microsoft Teams and records approve or hold decisions after Bot Framework authentication and tenant mapping checks."
  },
  "accentColor": "#0F766E",
  "bots": [
    {
      "botId": "${TEAMS_APP_ID}",
      "scopes": ["personal", "team", "groupchat"],
      "supportsFiles": false,
      "isNotificationOnly": false
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["surface.brain.fi", "localhost"]
}
