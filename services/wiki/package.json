{
  "name": "@brain/wiki",
  "version": "0.1.0",
  "private": true,
  "description": "Structured memory. Postgres + pgvector. Bitemporal entity/relation graph via recursive CTE.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.2",
    "vitest": "^3.2.0",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.12.0",
    "ioredis": "^5.4.1"
  },
  "dependencies": {
    "@brain/shared": "workspace:*",
    "@brain/schemas": "workspace:*",
    "fastify": "^5.0.0",
    "pg": "^8.13.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "@anthropic-ai/sdk": "^0.30.0",
    "openai": "^4.68.0"
  }
}
