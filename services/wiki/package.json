{
  "name": "@brain/wiki",
  "version": "0.1.0",
  "private": true,
  "description": "Structured memory. Postgres + pgvector. Bitemporal entity/relation graph via recursive CTE.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2",
    "@vitest/coverage-v8": "^2.1.2",
    "eslint": "^9.12.0"
  },
  "dependencies": {
    "@brain/api": "workspace:*"
  }
}
